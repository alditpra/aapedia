---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AApedia — Publikasi Artikel Jurnal Ilmiah',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      { text: 'Pelajari', href: '#legalitas' },
      {
        variant: 'primary',
        text: 'Lihat Jurnal',
        href: '/jurnal',
        icon: 'tabler:arrow-right',
      },
    ]}
    image={{ src: '~/assets/images/banner_belajar.webp', alt: 'AApedia Hero Image' }}
  >
    <Fragment slot="title">
      Dari Naskah Sampai Publikasi <br>
      <span class="text-accent dark:text-white highlight">Kami Siap Kasih Solusi</span>
    </Fragment>

    <Fragment slot="subtitle">
        <span class="font-semibold">AApedia</span> menawarkan berbagai layanan komprehensif untuk membantu institusi, akademisi, peneliti, dan mahasiswa dalam meraih kesuksesan melalui karya ilmiah
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note />

<!-- Features2 Widget ************** -->

  <Features
    id="legalitas"
    tagline="Legalitas"
    title="Sekilas Tentang"
    subtitle="AApedia adalah lembaga penerbitan resmi (AHU x/x/2024) yang didirikan oleh komunitas akademis untuk layanan publikasi dan karya tulis ilmiah secara profesional. <br><br>Article Access Academic Assistance Assessment Available Analysis Application Advice Advancement Affordable Author Accesible Accreditation Archive Articulate Authentic Action Actual Accelerate Apprentice Awesome Aim Always Adapt Anything Alliance Alternative Amplify Acknowledge Ahead Around Attack!"
  />

<!-- Features2 Widget ************** -->

  <Features2
    id="layanan"
    title="Apa yang AApedia Tawarkan"
    subtitle="Kami percaya bahwa pendidikan, penelitian, dan pengabdian kepada masyarakat (PkM) salah satu kunci untuk kemajuan bangsa. Oleh karena itu, kami berkomitmen untuk menyediakan layanan yang berkaitan dengan karya tulis ilmiah."
    tagline="Layanan"
    items={[
      {
        title: 'Publikasi Artikel Jurnal',
        description: "Pilih jurnal sesuai ruang lingkup dan terbitkan artikel ilmiah Anda di jurnal yang kredibel.",
        icon: 'flat-color-icons:approval',
        callToAction: {
        variant: 'primary',
        icon: 'tabler:arrow-right',
          text: `Selengkapnya`,
          href: '/jurnal',
        },
      },
      {
        title: 'Webinar dan Pelatihan',
        description:
          'Diadakan gratis secara berkala untuk meningkatkan pengetahuan tentang karya tulis.',
        icon: 'flat-color-icons:voice-presentation',
        callToAction: {
          text: `Selengkapnya`,
        icon: 'tabler:arrow-right',
          href: ('https://aapedia.netlify.app/category/webinar'),
        },
      },
      {
        title: 'Penulisan Karya Ilmiah',
        description:
          "Jasa pendampingan artikel jurnal berkualitas mengikuti standar jurnal yang dituju.",
        icon: 'flat-color-icons:document',
        callToAction: {
          text: `coming soon`,
          href: '#nilaiplus',
        },
      },
      {
        title: 'Translate / Penerjemah',
        description:
          'Jasa translasi artikel dari bahasa Indonesia ke Inggris atau sebaliknya.',
        icon: 'flat-color-icons:advertising',
        callToAction: {
          text: `coming soon`,
          href: '#nilaiplus',
        },
      },
      {
        title: 'Website Jurnal',
        description: 'Jasa gratis instalasi jurnal OJS untuk institusi atau lembaga dengan SK pendirian yang jelas.',
        icon: 'flat-color-icons:template',
        callToAction: {
          text: `coming soon`,
          href: '#nilaiplus',
        },
      },
      {
        title: 'Server Jurnal',
        description: 'Biarkan kami mengurus server, update, backup, desain. Fokuslah pada manajemen publikasi.',
        icon: 'flat-color-icons:template',
        callToAction: {
          text: `coming soon`,
          href: '#nilaiplus',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

<!-- Features Widget *************** -->

  <Features
    id="nilaiplus"
    tagline="Nilai Plus"
    title="Kenapa AApedia?"
    subtitle="Memilih mitra yang tepat untuk kebutuhan asistensi akademis Anda sangatlah penting. AApedia hadir sebagai solusi terpercaya untuk membantu Anda mencapai kesuksesan akademis."
    items={[
      {
        title: 'Tim Profesional',
        description:
          'AApedia didukung oleh profesional yang terdiri dari para ahli di bidang penelitian dan publikasi ilmiah dengan pengalaman bertahun-tahun.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Layanan Komprehensif',
        description:
          'Kami menawarkan berbagai layanan yang komprehensif untuk memenuhi kebutuhan Anda, mulai dari penerbitan, penulisan artikel ilmiah, skripsi, hingga pembuatan website jurnal.',
        icon: 'tabler:components',
      },
      {
        title: 'Efisiensi',
        description:
          'Kami memahami bahwa waktu Anda sangat berharga. Oleh karena itu, kami selalu berusaha untuk menyelesaikan pekerjaan dengan efisien tanpa mengorbankan kualitas.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Biaya Fleksibel',
        description:
          'Kami menawarkan berbagai pilihan paket dengan biaya yang terjangkau dan fleksibel menyesuaikan dengan kebutuhan Anda.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Komunikasi Jelas dan Terbuka',
        description:
          'Kami selalu menjaga komunikasi yang jelas dan terbuka dengan para klien selama proses berlangsung.',
        icon: 'tabler:arrows-right-left',
      },
      {
        title: 'Integritas',
        description:
          'Kami menjunjung tinggi kejujuran dan profesionalisme dalam setiap layanan yang kami berikan.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Konsultasi Gratis"
    subtitle="Fokuskan waktu berharga Anda pada hal lain"
    items={[
      {
        title: 'Langkah 1: <span class="font-medium">Hubungi / Isi Formulir</span>',
        description:
          "Jelaskan secara singkat kebutuhan asistensi akademis Anda, seperti jenis layanan yang dibutuhkan, deadline, dan informasi lainnya yang relevan. Tim AApedia akan segera menghubungi Anda untuk mendiskusikan kebutuhan Anda lebih lanjut dan memberikan penawaran terbaik.",
        icon: 'tabler:package',
      },
      {
        title: 'Langkah 2: <span class="font-medium">Diskusi</span>',
        description:
          "Dapatkan konsultasi gratis dengan tim ahli AApedia untuk membahas kebutuhan asistensi akademis Anda secara lebih mendalam. Anda dapat mengajukan pertanyaan, mendapatkan saran, dan menyepakati biaya yang diperlukan.",
        icon: 'tabler:letter-case',
      },
      {
        title: 'Langkah 3: <span class="font-medium">Proses Pengerjaan</span>',
        description:
          "Setelah Anda yakin dengan layanan kami, tim kami akan segera mengerjakan permintaan Anda. Kami akan memberikan update berkala tentang kemajuan permintaan hingga selesai.",
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>



  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faq"
    title="Pertanyaan Umum"
    subtitle="Tanya jawab apa saja yang sering diajukan tentang AApedia"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Apa latar belakang dari AApedia?',
        description:
          "Kami berawal dari sebuah komunitas akademisi yang berbagi semangat dalam penelitian dan karya tulis ilmiah. Seiring berkembangnya waktu, kami melihat kebutuhan akan layanan yang lebih terstruktur. AApedia didirikan dengan tujuan untuk memenuhi kebutuhan tersebut secara profesional.",
      },
      {
        title: 'Apa saja ruang lingkup serta pilihan jurnal untuk publikasi?',
        description:
          "AApedia membantu penerbitan di berbagai jurnal kredibel dan terindeks, baik nasional maupun internasional. Tim kami akan membantu Anda memilih jurnal yang tepat sesuai dengan bidang penelitian dan target publikasi Anda.",
      },
      {
        title: 'Berapa lama waktu yang dibutuhkan untuk menyelesaikan jasa penulisan artikel jurnal?',
        description:
          'Waktu penyelesaian jasa penulisan artikel jurnal di AApedia bervariasi tergantung pada kompleksitas topik, panjang artikel, dan ketersediaan tim.',
      },
      {
        title: "Apakah AApedia menyediakan jasa revisi setelah artikel jurnal selesai?",
        description:
          "Ya, AApedia menyediakan jasa revisi untuk memastikan artikel jurnal atau skripsi Anda memenuhi standar kualitas dan siap untuk diterbitkan atau dipresentasikan.",
      },
      {
        title: 'Apa saja metode statistik yang ditawarkan AApedia untuk analisis data?',
        description:
          "AApedia menawarkan berbagai metode statistik untuk analisis data penelitian, termasuk analisis deskriptif, analisis inferensial, regresi linier,  dsb. Tim ahli statistik kami akan membantu Anda memilih metode yang tepat untuk data dan tujuan penelitian Anda",
      },
      {
        title: 'Saya perlu membuat artikel jurnal tetapi bingung harus dimulai dari mana?',
        description:
          "Jangan ragu untuk konsultasi gratis, silahkan hubungi kami.",
      },
    ]}
  />


  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Hubungi Kami',
        href: 'https://wa.me/6287851150691',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      AApedia &nbsp;<br class="block sm:hidden" /> Academic Assistance
    </Fragment>

    <Fragment slot="subtitle">
      Hubungi kami sekarang untuk konsultasi gratis &nbsp;<br class="hidden md:inline" />Jangan sampai tugasmu tertunda!
    </Fragment>
  </>
</Layout>
